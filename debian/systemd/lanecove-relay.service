[Unit]
Description=Lane Cove Tunnel - Relay
After=network-online.target
Wants=network-online.target

[Service]
ExecStartPre=/usr/share/lanecove-tunnel/create-peer-tunnel.sh lanecove0 10.9.0.1/24
ExecStart=/usr/bin/lanecove-peer -c /etc/lanecove/relay.yaml
Restart=on-failure
RestartSec=5
AmbientCapabilities=CAP_NET_ADMIN

[Install]
WantedBy=multi-user.target
